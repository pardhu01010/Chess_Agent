# =============================================================================
# Chess Agent — .gitignore
# =============================================================================

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
env/
venv/
.venv/

# ── Environment variables ──────────────────────────────────────────────────────
.env
.env.*

# ── IDE / Editor settings ──────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── OS artifacts ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log

# ── PyTorch model files ────────────────────────────────────────────────────────
# Keep the final trained model but ignore intermediate checkpoints
chess_model_checkpoint_*.pth
chess_model_trained.pth

# ── Training output ─────────────────────────────────────────────────────────── 
training_progress.png

# ── Scratch / temp files ───────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
.txt

# ── Build / distribution ───────────────────────────────────────────────────────
build/
dist/
*.egg-info/

# ── Jupyter Notebook checkpoints ───────────────────────────────────────────────
.ipynb_checkpoints/